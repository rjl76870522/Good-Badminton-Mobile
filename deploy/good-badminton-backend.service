[Unit]
Description=Good Badminton backend API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=john
Group=john
WorkingDirectory=/data/projects/Good-Badminton-1
Environment=PYTHONPATH=/data/projects/Good-Badminton-1
Environment=ALL_PROXY=
Environment=all_proxy=
Environment=NO_PROXY=*
Environment=no_proxy=*
Environment=ANALYSIS_WORKERS=4
Environment=STORAGE_WARNING_PERCENT=70
Environment=STORAGE_BLOCK_PERCENT=80
ExecStart=/data/projects/Good-Badminton-1/start_backend.sh
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
